---
layout: null
permalink: /assets/js/search-index.json
---
[
  {% assign all_items = site.posts | concat: site.projects | concat: site.publications %}
  {% for item in all_items %}
    {
      "title": {{ item.title | jsonify }},
      "url": {{ item.url | relative_url | jsonify }},
      "excerpt": {{ item.summary | default: item.excerpt | strip_html | truncatewords: 24 | jsonify }},
      "tags": {{ item.tags | default: item.categories | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
